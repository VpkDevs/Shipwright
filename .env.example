# GitHub OAuth
GITHUB_ID=your_github_app_id_here
GITHUB_SECRET=your_github_app_secret_here

# Next.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_generated_secret_here

# Optional: Vercel API (for PR automation)
VERCEL_API_TOKEN=your_vercel_token_here

# Optional: Anthropic API (for AI-enhanced README/landing page generation)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Dev mode (set both to use a personal GitHub token instead of OAuth)
# DEV_MODE=true
# DEV_GITHUB_TOKEN=your_github_personal_access_token
