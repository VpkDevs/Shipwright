# Database (Vercel Postgres)
DATABASE_URL=postgres://user:password@host/dbname

# GitHub OAuth
GITHUB_ID=your_github_app_id_here
GITHUB_SECRET=your_github_app_secret_here

# Next.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_generated_secret_here

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-project.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# AI Generation (Google Gemini)
GEMINI_API_KEY=your_api_key_here

# Optional: Vercel API (for PR automation)
VERCEL_API_TOKEN=your_vercel_token_here

# Optional: Anthropic API (for advanced README/landing page generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Development mode (bypasses GitHub OAuth with a local token)
# DEV_MODE=true
# DEV_GITHUB_TOKEN=your_personal_access_token_here
