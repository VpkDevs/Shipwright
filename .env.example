# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your_github_oauth_client_id
GITHUB_SECRET=your_github_oauth_client_secret

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get at: https://platform.openai.com/api-keys
# Model used: gpt-4o-mini (cost-efficient)
OPENAI_API_KEY=sk-...

# ─── Blackbox AI ──────────────────────────────────────────────────────────────
# Get at: https://www.blackbox.ai/api
BLACKBOX_API_KEY=your_blackbox_api_key

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get at: https://dashboard.stripe.com/apikeys
# Use TEST keys for development, LIVE keys for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard → Products)
# Product 1: "Ship Credit" — One-time payment, $5
STRIPE_PRICE_CREDIT=price_...
# Product 2: "Pro Monthly" — Recurring subscription, $15/month
STRIPE_PRICE_PRO=price_...
# Product 3: "Pro Annual" — Recurring subscription, billed yearly
STRIPE_PRICE_PRO_ANNUAL=price_...
# Product 4: "Team Launch" — Recurring subscription for agency/internal teams
STRIPE_PRICE_TEAM=price_...

# Analytics storage path
# Use a persistent mounted volume in production if you want retained event history.
ANALYTICS_STORAGE_PATH=.data/analytics/events.jsonl

# ─── Dev Mode (optional) ──────────────────────────────────────────────────────
# Set to "true" to enable dev login bypass (development only)
DEV_MODE=true
# Optional: real GitHub token for dev mode API calls
DEV_GITHUB_TOKEN=ghp_...

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL database URL
DATABASE_URL=postgres://user:password@host/dbname

# ─── Rate Limiting (Upstash Redis) ────────────────────────────────────────────
# Get at: https://console.upstash.com
# Create a Redis database and get the REST URL and token
UPSTASH_REDIS_REST_URL=https://your-project.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ─── AI Generation (Google Gemini) ────────────────────────────────────────────
# Get at: https://ai.google.dev
# API key for Google Generative AI
GEMINI_API_KEY=your_api_key_here
